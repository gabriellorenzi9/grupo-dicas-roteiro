{
  "rewrites": [
    {
      "source": "/api/roteiro",
      "destination": "/api/roteiro.js"
    },
    {
      "source": "/api/gerar",
      "destination": "/api/gerar.js"
    },
    {
      "source": "/api/teste",
      "destination": "/api/teste.js"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://grupodicas.com https://www.grupodicas.com https://*.grupodicas.com"
        }
      ]
    }
  ]
}
